{
  "name": "mail-cleanup",
  "version": "1.4.0",
  "description": "Interactive CLI tool to triage and bulk-manage unread emails from Gmail and Outlook",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "build": "bun build --compile src/index.js --outfile dist/mail-cleanup",
    "build:win": "bun build --compile src/index.js --outfile dist/mail-cleanup.exe --target bun-windows-x64 && node scripts/patch-exe.mjs",
    "build:mac": "bun build --compile src/index.js --outfile dist/mail-cleanup-mac --target bun-darwin-x64",
    "build:linux": "bun build --compile src/index.js --outfile dist/mail-cleanup-linux --target bun-linux-x64",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@azure/msal-node": "^2.16.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "inquirer": "^9.3.7",
    "node-fetch": "^3.3.2",
    "open": "^10.1.0",
    "ora": "^8.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "rcedit": "^5.0.2"
  }
}
