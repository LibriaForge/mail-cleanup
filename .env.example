# Anthropic (for AI classification)
ANTHROPIC_API_KEY=

# Gmail OAuth2 credentials
# Create at https://console.cloud.google.com/ → APIs & Services → Credentials
# Application type: Desktop app or Web application
# Authorized redirect URI: http://localhost:3000/oauth2callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Outlook / Microsoft Graph credentials
# Register at https://portal.azure.com/ → Azure Active Directory → App registrations
# Platform: Mobile and desktop applications
# Redirect URI: https://login.microsoftonline.com/common/oauth2/nativeclient
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=common
